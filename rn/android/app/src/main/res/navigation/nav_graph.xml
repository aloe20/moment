<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
  xmlns:app="http://schemas.android.com/apk/res-auto"
  xmlns:tools="http://schemas.android.com/tools"
  android:id="@+id/nav_graph"
  app:startDestination="@+id/frag_splash">
  <fragment
    android:id="@+id/frag_splash"
    android:name="com.aloe.moment.business.splash.SplashFrag">
    <action
      android:id="@+id/action_frag_splash_to_frag_home"
      app:destination="@id/frag_home"
      app:popUpTo="@id/frag_splash"
      app:popUpToInclusive="true" />
  </fragment>
  <fragment
    android:id="@+id/frag_home"
    android:name="com.aloe.moment.business.home.HomeFrag"
    tools:layout="@layout/frag_home">
    <action
      android:id="@+id/action_frag_home_to_frag_web"
      app:destination="@id/frag_web" />
    <action
      android:id="@+id/action_frag_home_to_frag_react"
      app:destination="@id/frag_react" />
    <action
      android:id="@+id/action_frag_home_to_frag_article_search"
      app:destination="@id/frag_article_search" />
    <action
      android:id="@+id/action_frag_home_to_frag_project_classify"
      app:destination="@id/frag_project_classify" />
    <action
      android:id="@+id/action_frag_home_to_frag_hierarchy_detail"
      app:destination="@id/frag_hierarchy_detail" />
  </fragment>
  <fragment
    android:id="@+id/frag_project_classify"
    android:name="com.aloe.moment.business.project.classify.ClassifyFrag"
    android:label="@string/project_classify"
    tools:layout="@layout/layout_tab">
    <action
      android:id="@+id/action_frag_project_classify_to_frag_web"
      app:destination="@id/frag_web" />
  </fragment>
  <fragment
    android:id="@+id/frag_web"
    android:name="com.aloe.moment.business.web.WebFrag"
    tools:layout="@layout/frag_web">
    <argument
      android:name="data"
      app:argType="com.aloe.bean.WebBean" />
  </fragment>
  <fragment
    android:id="@+id/frag_react"
    android:name="com.aloe.moment.business.react.ReactFrag"
    android:label="@string/react" />
  <fragment
    android:id="@+id/frag_article_search"
    android:name="com.aloe.moment.business.article.search.SearchFrag"
    tools:layout="@layout/frag_article_hotkey">
    <action
      android:id="@+id/action_frag_article_search_to_frag_article_child"
      app:destination="@id/frag_article_child" />
  </fragment>
  <fragment
    android:id="@+id/frag_article_child"
    android:name="com.aloe.moment.business.article.ArticleChildFrag"
    tools:layout="@layout/frag_article_child">
    <argument
      android:name="data"
      app:argType="com.aloe.bean.ClassifyBean" />
    <action
      android:id="@+id/action_frag_article_child_to_frag_web"
      app:destination="@id/frag_web" />
  </fragment>
  <fragment
    android:id="@+id/frag_hierarchy_detail"
    android:name="com.aloe.moment.business.hierarchy.HierarchyDetailFrag"
    tools:layout="@layout/layout_tab">
    <action
      android:id="@+id/action_frag_hierarchy_detail_to_frag_web"
      app:destination="@id/frag_web" />
    <argument
      android:name="tree_classify_id"
      android:defaultValue="0"
      app:argType="integer" />
    <argument
      android:name="tree_child_id"
      android:defaultValue="0"
      app:argType="integer" />
  </fragment>
  <fragment
    android:id="@+id/frag_video"
    android:name="com.aloe.moment.business.video.VideoFrag" />
</navigation>